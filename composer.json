{
    "name": "mrorko840/laravel-ai-analytics",
    "description": "Universal AI-powered analytics and reporting package for Laravel.",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "mrorko840",
            "email": "author@example.com"
        }
    ],
    "require": {
        "php": "^8.2",
        "illuminate/support": "^10.0|^11.0",
        "illuminate/contracts": "^10.0|^11.0",
        "illuminate/database": "^10.0|^11.0",
        "illuminate/routing": "^10.0|^11.0",
        "illuminate/console": "^10.0|^11.0",
        "guzzlehttp/guzzle": "^7.8",
        "barryvdh/laravel-dompdf": "^2.2|^3.0"
    },
    "require-dev": {
        "orchestra/testbench": "^8.0|^9.0",
        "phpunit/phpunit": "^10.0|^11.0",
        "mockery/mockery": "^1.6"
    },
    "autoload": {
        "psr-4": {
            "Mrorko840\\AiAnalytics\\": "src/"
        },
        "files": [
            "src/Support/helpers.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Mrorko840\\AiAnalytics\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Mrorko840\\AiAnalytics\\AiAnalyticsServiceProvider"
            ],
            "aliases": {
                "AiAnalytics": "Mrorko840\\AiAnalytics\\Facades\\AiAnalytics"
            }
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
